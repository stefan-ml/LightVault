@page "/secrets/add"
@rendermode InteractiveServer

@using LightVault.WebApplication.Services
@using LightVault.WebApplication.Models
@using Microsoft.AspNetCore.Components.Authorization

@inject SecretService _secretService
@inject NavigationManager _nav

<h3>➕ Add New Secret</h3>

<AuthorizeView Roles="Admin,Developer">
    <Authorized Context="auth">
        <EditForm Model="_model" OnValidSubmit="CreateSecret">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label class="form-label">Name</label>
                <InputText class="form-control" @bind-Value="_model.Name" />
            </div>

            <div class="mb-3">
                <label class="form-label">Value</label>
                <InputTextArea class="form-control" rows="4" @bind-Value="_model.Value" />
            </div>

            <button class="btn btn-primary" type="submit" disabled="@_submitting">
                @(_submitting ? "Creating..." : "Create Secret")
            </button>

            <button class="btn btn-secondary ms-2" type="button" @onclick="BackToList">
                Cancel
            </button>

            @if (!string.IsNullOrEmpty(_error))
            {
                <p class="text-danger mt-3">@_error</p>
            }
        </EditForm>
    </Authorized>

    <NotAuthorized>
        <p>You are not authorized. Redirecting...</p>
    </NotAuthorized>
</AuthorizeView>

@code {
    private CreateSecretRequest _model = new();
    private bool _submitting = false;
    private string? _error;

    [CascadingParameter] public Task<AuthenticationState> AuthTask { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthTask;
        if (!auth.User.Identity?.IsAuthenticated ?? true)
        {
            _nav.NavigateTo("/login", forceLoad: true);
        }
    }

    private async Task CreateSecret()
    {
        _submitting = true;
        _error = null;

        try
        {
            var id = await _secretService.Create(_model);

            if (id != Guid.Empty)
            {
                _nav.NavigateTo($"/secrets/{id}");
                return;
            }

            _error = "Failed to create secret.";
        }
        catch (Exception ex)
        {
            _error = "Error: " + ex.Message;
        }

        _submitting = false;
    }

    private void BackToList() => _nav.NavigateTo("/secrets");
}
