@page "/secrets/{Id:guid}/rotate"
@rendermode InteractiveServer

@using LightVault.WebApplication.Services
@using LightVault.WebApplication.Models
@using Microsoft.AspNetCore.Components.Authorization
@inject SecretService _secretService
@inject NavigationManager _nav

<h3>🔁 Rotate Secret</h3>

<AuthorizeView Roles="Admin,Developer">
    <Authorized Context="authState">

        <EditForm Model="_model" OnValidSubmit="Rotate">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label class="form-label">New secret value</label>
                <InputText class="form-control"
                           @bind-Value="_model.NewValue" />
            </div>

            <button type="submit" class="btn btn-warning me-2">
                Rotate
            </button>

            <button type="button"
                    class="btn btn-secondary"
                    @onclick="Cancel">
                Cancel
            </button>
        </EditForm>

    </Authorized>
</AuthorizeView>

@code {
    [Parameter] public Guid Id { get; set; }

    private RotateSecretRequest _model = new();

    private async Task Rotate()
    {
        await _secretService.Rotate(Id, _model);
        _nav.NavigateTo($"/secrets/{Id}");
    }

    private void Cancel()
        => _nav.NavigateTo($"/secrets/{Id}");
}
