@page "/secrets/{id:guid}"
@using LightVault.WebApplication.Services
@using LightVault.WebApplication.Models
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject SecretService _secretService
@inject NavigationManager _nav
@inject AuthenticationStateProvider AuthStateProvider

<h3>🔐 Secret Details</h3>

<AuthorizeView Roles="Admin,Developer">
    <Authorized>
        @if (_loading)
        {
            <p>Loading...</p>
        }
        else if (_secret is null)
        {
            <p class="text-danger">Secret not found.</p>
        }
        else
        {
            <div class="card p-3 mb-3">
                <h4>@_secret.Name</h4>

                <p>
                    <strong>Current Version:</strong>
                    @_secret.CurrentVersion
                </p>

                @if (_secret.ExpiresAt != null)
                {
                    var isExpired = _secret.ExpiresAt < DateTime.UtcNow;

                    <p>
                        <strong>Expires At:</strong>
                        <span class="@(isExpired ? "text-danger" : "text-muted")">
                            @_secret.ExpiresAt.Value.ToString("yyyy-MM-dd HH:mm")
                        </span>
                    </p>

                    @if (isExpired)
                    {
                        <div class="alert alert-danger mt-2">
                            ⚠ This secret has expired. Rotation is required.
                        </div>
                    }
                }

                <div class="mt-3">
                    <label><strong>Decrypted Value:</strong></label>
                    <div class="border rounded p-2 bg-light">
                        @if (_secret.ExpiresAt != null && _secret.ExpiresAt < DateTime.UtcNow)
                        {
                            <em class="text-muted">
                                Secret expired. Rotate to access a new value.
                            </em>
                        }
                        else
                        {
                            @_secret.Value
                        }
                    </div>
                </div>

                <div class="mt-3">
                    <button class="btn btn-warning"
                            disabled="@(!_secret.CanModifySecret)"
                            @onclick="GoToRotate">
                        🔁 Rotate Secret
                    </button>

                    @if (_secret.ExpiresAt != null && _secret.ExpiresAt < DateTime.UtcNow)
                    {
                        <span class="ms-2 text-danger fw-bold">
                            Required
                        </span>
                    }
                </div>
            </div>

            <h5>Versions</h5>
            <table class="table">
                <thead>
                    <tr>
                        <th>Version</th>
                        <th>Created At</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in _secret.Versions)
                    {
                        <tr>
                            <td>@v.Version</td>
                            <td>@v.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                @if (_secret.ExpiresAt != null
                                                        && _secret.ExpiresAt < DateTime.UtcNow
                                                        && v.Version == _secret.CurrentVersion)
                                {
                                    <span class="badge bg-danger">Expired</span>
                                }
                                else if (v.Version == _secret.CurrentVersion)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Old</span>
                                }
                            </td>
                            <td>
                                <button class="btn btn-sm btn-primary"
                                        @onclick="() => LoadVersion(v.Version)">
                                    Load version
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <button class="btn btn-secondary" @onclick="BackToList">
                ⬅ Back to list
            </button>
        }
    </Authorized>

    <NotAuthorized>
        <p>You are not authorized. Redirecting...</p>
    </NotAuthorized>
</AuthorizeView>

@code {
    [Parameter] public Guid Id { get; set; }

    private SecretDetailsDto? _secret;
    private bool _loading = true;

    [CascadingParameter]
    public Task<AuthenticationState> AuthStateTask { get; set; } = null!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var auth = await AuthStateTask;
        var user = auth.User;

        if (!user.Identity?.IsAuthenticated ?? true)
        {
            _nav.NavigateTo("/login", forceLoad: true);
            return;
        }

        await LoadSecret();
        StateHasChanged();
    }

    private async Task LoadSecret()
    {
        _loading = true;
        _secret = await _secretService.GetById(Id);
        _loading = false;
    }

    private async Task LoadVersion(int version)
    {
        var details = await _secretService.GetVersion(Id, version);
        if (details != null)
        {
            _secret!.Value = details.Value;
            _secret.CurrentVersion = version;
        }
    }

    private void GoToRotate()
    {
        _nav.NavigateTo($"/secrets/{Id}/rotate");
    }

    private void BackToList()
    {
        _nav.NavigateTo("/secrets");
    }
}
