@page "/admin/service-accounts"
@rendermode InteractiveServer

@using LightVault.WebApplication.Services
@inject ApiClient Api
@inject NavigationManager _nav
@using Microsoft.AspNetCore.Components.Authorization

<h3>🔑 Service Accounts</h3>

<AuthorizeView Roles="Admin">
    <Authorized>

        <div class="card p-3 mb-3">
            <h5>Create Service Account</h5>

            <div class="mb-3">
                <label>Application Name</label>
                <InputText class="form-control" @bind-Value="newAppName" />
            </div>

            <div class="mb-3">
                <label>Role</label>
                <InputText class="form-control" @bind-Value="newRole"/>
            </div>

            <button class="btn btn-primary" @onclick="CreateServiceAccount">
                Generate API Key
            </button>
        </div>

        @if (!string.IsNullOrWhiteSpace(generatedApiKey))
        {
            <div class="alert alert-warning">
                <strong>Copy this API key now. It will not be shown again.</strong>
                <br />
                <code>@generatedApiKey</code>
            </div>
        }

        <h5 class="mt-4">Existing Accounts</h5>

        @if (accounts is null)
        {
            <p>Loading...</p>
        }
        else
        {
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>App</th>
                        <th>Role</th>
                        <th>Active</th>
                        <th>Created</th>
                        <th>Last Used</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var acc in accounts)
                    {
                        <tr>
                            <td>@acc.AppName</td>
                            <td>@acc.Role</td>
                            <td>@(acc.IsActive ? "Yes" : "No")</td>
                            <td>@acc.CreatedAtUtc.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@(acc.LastUsedAtUtc?.ToString("dd.MM.yyyy HH:mm") ?? "-")</td>
                            <td>
                                @if (acc.IsActive)
                                {
                                    <button class="btn btn-danger btn-sm"
                                            @onclick="() => Revoke(acc.Id)">
                                        Revoke
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

    </Authorized>

    <NotAuthorized>
        <p class="text-danger">You are not authorized to manage service accounts.</p>
    </NotAuthorized>
</AuthorizeView>

@code {
    private string newAppName = "";
    private string newRole = "ServiceClient";
    private string? generatedApiKey;
    private List<ServiceAccountDto>? accounts;

    [CascadingParameter] public Task<AuthenticationState> AuthTask { get; set; } = null!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var auth = await AuthTask;

        if (!auth.User.Identity?.IsAuthenticated ?? true)
        {
            _nav.NavigateTo("/login", forceLoad: true);
            return;
        }

        if (!auth.User.IsInRole("Admin"))
        {
            _nav.NavigateTo("/");
            return;
        }

        await LoadAccounts();
        StateHasChanged();
    }

    private async Task LoadAccounts()
    {
        accounts = await Api.GetAsync<List<ServiceAccountDto>>(
            "api/service-accounts");
    }

    private async Task CreateServiceAccount()
    {
        var response = await Api.PostAsync<CreateServiceAccountResponse>(
            "api/service-accounts",
            new
            {
                AppName = newAppName,
                Role = newRole
            });

        if (response != null)
        {
            generatedApiKey = response.ApiKey;
            await LoadAccounts();
        }
    }

    private async Task Revoke(Guid id)
    {
        await Api.DeleteAsync($"api/service-accounts/{id}");
        await LoadAccounts();
    }

    private class ServiceAccountDto
    {
        public Guid Id { get; set; }
        public string AppName { get; set; } = "";
        public string Role { get; set; } = "";
        public bool IsActive { get; set; }
        public DateTime CreatedAtUtc { get; set; }
        public DateTime? LastUsedAtUtc { get; set; }
    }

    private class CreateServiceAccountResponse
    {
        public Guid Id { get; set; }
        public string AppName { get; set; } = "";
        public string Role { get; set; } = "";
        public string ApiKey { get; set; } = "";
    }
}